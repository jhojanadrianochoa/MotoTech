# ==============================
# COPIA ESTE ARCHIVO A .env
# NO subas .env a GitHub
# ==============================

# MongoDB Atlas — obtén tu URI en: https://cloud.mongodb.com
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://TU_USUARIO:TU_PASSWORD@cluster0.xxxxx.mongodb.net/mototech

# Puerto local del servidor
PORT=3001

# Orígenes permitidos (tu frontend en Vercel/Netlify + local)
# Separa múltiples orígenes con coma
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://TU-APP.vercel.app,https://TU-APP.netlify.app
